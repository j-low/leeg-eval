# Base URL of the running leeg-app instance
LEEG_API_URL=http://localhost:8000

# Captain JWT obtained from POST /api/auth/login (or set email/password to auto-acquire)
LEEG_API_TOKEN=

# Alternatively, provide credentials and the runner will fetch a token at startup
LEEG_API_EMAIL=admin@example.com
LEEG_API_PASSWORD=changeme

# Anthropic model used for LLM-as-judge scoring
# Default: claude-haiku-4-5-20251001 (fast, cheap; different family from the pipeline model reduces self-serving bias)
JUDGE_MODEL=claude-haiku-4-5-20251001

# Anthropic API key for judge calls
ANTHROPIC_API_KEY=sk-ant-...
